                {"title": "CHANNELS: Community/Word-of-mouth"},
                {"title": "CHANNELS: Events/Webinars"},
                {"title": "PRIORITIZE: Score channels on reach, cost, fit"},
                {"title": "PRIORITIZE: Select 2-3 primary channels to test"},
                {"title": "BUDGET: Allocate initial marketing budget"},
                {"title": "BUDGET: Set CAC targets by channel"},
                {"title": "Channel strategy documented"},
                {"title": "EXIT: GTM motion and initial channels selected"}
